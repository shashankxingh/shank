{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Shank",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.shank",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.shank",
          "match": "\\b(if|elif|else|while|for|in|return|break|continue|match|case)\\b"
        },
        {
          "name": "keyword.other.shank",
          "match": "\\b(let|mut|fn|struct|enum|import)\\b"
        },
        {
          "name": "constant.language.shank",
          "match": "\\b(true|false|none)\\b"
        },
        {
          "name": "keyword.operator.logical.shank",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.shank",
          "match": "\\b(int|float|bool|str)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.shank",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.shank",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.shank",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.shank",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.other.shank"
            },
            "2": {
              "name": "entity.name.function.shank"
            }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "name": "entity.name.function.call.shank"
        }
      ]
    }
  },
  "scopeName": "source.shank"
}
