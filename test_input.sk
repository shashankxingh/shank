fn main():
    im int age = put("Enter your age: ")
    im str name = put("Enter your name: ")
    im float height = put("Enter your height: ")
    im bool cool = put("Are you cool? (true/false): ")

    out "Hello {name}, you are {age} years old."
    out "Your height is {height}."
    out "Is cool? {cool}"

main()
