im int n = 5

repeat n as i:
    im int left_spaces = n - i - 1
    im int inside_spaces = (i * 2) - 1
    out left_spaces
    out inside_spaces
    out "---"

repeat n - 1 as i:
    im int stars_row = n - i - 2
    im int left_spaces = i + 1
    im int inside_spaces = (stars_row * 2) - 1
    out left_spaces
    out inside_spaces
    out "---"
