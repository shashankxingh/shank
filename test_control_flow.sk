fn main():
    out "--- Testing Type Casting ---"
    im float pi = 3.14159
    im int rounded = pi -> int
    out "Pi is {pi}, rounded is {rounded}"
    
    im int x = 42
    im float xf = x -> float
    out "x is {x}, as float is {xf}"
    
    out "--- Testing When / Otherwise ---"
    im int age = 20
    
    when age >= 18:
        out "You are an adult."
        when age == 18:
            out "You just became an adult!"
        otherwise:
            out "You've been an adult for a while."
    otherwise:
        out "You are a minor."
        
    out "--- Testing Repeat Loop ---"
    repeat 5 as i:
        out "Loop iteration {i}"
        
main()
